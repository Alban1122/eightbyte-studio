generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Review {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(100)
  company   String   @db.VarChar(100)
  rating    Int
  message   String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("reviews")
}
